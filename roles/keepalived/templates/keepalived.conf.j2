! =============================================================
! keepalived.conf - {{ inventory_hostname | upper }}
! Gestionat de Ansible - NU modifica manual
! =============================================================

global_defs {
    router_id {{ inventory_hostname }}
    script_user root
    enable_script_security
    notification_email_from keepalived@localhost
    smtp_connect_timeout 30
    vrrp_garp_interval 0.001
}

vrrp_script check_pgsql {
    script "/etc/keepalived/check_pgsql.sh"
    interval 3
    timeout 5
    rise 2
    fall 3
    weight -20
}

vrrp_script check_crowdsec {
    script "/etc/keepalived/check_crowdsec.sh"
    interval 5
    timeout 5
    rise 2
    fall 3
    weight -10
}

vrrp_instance VI_CROWDSEC {
    state {{ keepalived_state }}
    interface {{ vip_interface }}
    virtual_router_id {{ keepalived_router_id }}
    priority {{ keepalived_priority }}
    advert_int 1
    preempt_delay 10

    authentication {
        auth_type PASS
        auth_pass {{ keepalived_auth_pass }}
    }

    unicast_src_ip {{ ansible_host }}
    unicast_peer {
{% for host in groups['crowdsec_ha'] %}
{% if hostvars[host]['ansible_host'] != ansible_host %}
        {{ hostvars[host]['ansible_host'] }}
{% endif %}
{% endfor %}
    }

    virtual_ipaddress {
        {{ vip_address }}/24 dev {{ vip_interface }} label {{ vip_interface }}:0
    }

    track_script {
        check_pgsql
        check_crowdsec
    }

    notify_master "/etc/keepalived/notify_master.sh"
    notify_backup "/etc/keepalived/notify_backup.sh"
    notify_fault  "/etc/keepalived/notify_fault.sh"
}
