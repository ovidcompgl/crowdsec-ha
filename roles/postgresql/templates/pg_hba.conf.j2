# TYPE  DATABASE        USER                ADDRESS                 METHOD
local   all             postgres                                    peer
local   all             all                                         peer
host    all             all                 127.0.0.1/32            scram-sha-256
host    all             all                 ::1/128                 scram-sha-256

# Acces CrowdSec de pe ambele noduri si VIP
host    {{ postgresql_crowdsec_db }}   {{ postgresql_crowdsec_user }}   10.10.100.0/24   scram-sha-256

# Replicare
host    replication     {{ postgresql_replication_user }}   10.10.100.0/24   scram-sha-256
