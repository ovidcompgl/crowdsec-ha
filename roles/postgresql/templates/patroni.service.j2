[Unit]
Description=Patroni - HA PostgreSQL Agent
Documentation=https://patroni.readthedocs.io/
After=network.target

[Service]
Type=simple
User=postgres
Group=postgres
ExecStart=/usr/local/bin/patroni /etc/patroni/patroni.yml
ExecReload=/bin/kill -s HUP $MAINPID
KillMode=process
TimeoutSec=30
Restart=on-failure
RestartSec=5s

# Logging
StandardOutput=append:/var/log/patroni/patroni.log
StandardError=append:/var/log/patroni/patroni.log

# Securitate
NoNewPrivileges=yes
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
